# ============================================
# Bjorq Asset Wizard — Backend Environment
# ============================================

# Server
PORT=3500
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Storage
STORAGE_PATH=./storage
CATALOG_PATH=./public/catalog

# Upload limits
MAX_FILE_SIZE_MB=100

# Thumbnail
THUMBNAIL_SIZE=512
THUMBNAIL_FORMAT=webp
THUMBNAIL_QUALITY=80

# Optimization defaults
DEFAULT_MAX_TEXTURE_SIZE=2048
DEFAULT_TEXTURE_QUALITY=85

# CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=*

# Job cleanup (hours before temp jobs are deleted, 0 = never)
JOB_RETENTION_HOURS=24
