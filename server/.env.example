# ============================================
# Bjorq Asset Wizard — Backend Environment
# ============================================

# Server
PORT=3500
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Logging
# Set LOG_FILE to also write logs to a file (JSON format).
# Leave empty to log to stdout only.
LOG_FILE=

# Storage
STORAGE_PATH=/data/storage
CATALOG_PATH=/data/catalog

# Upload limits
MAX_FILE_SIZE_MB=100

# Thumbnail
THUMBNAIL_SIZE=512
THUMBNAIL_FORMAT=webp
THUMBNAIL_QUALITY=80

# Optimization defaults
DEFAULT_MAX_TEXTURE_SIZE=2048
DEFAULT_TEXTURE_QUALITY=85

# CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=*

# Job cleanup (hours before temp jobs are deleted, 0 = never)
JOB_RETENTION_HOURS=24

# ============================================
# TRELLIS — Photo → 3D Engine
# ============================================

# Mode: "local" = install TRELLIS in this container (requires Linux + NVIDIA GPU)
#        "external" = proxy to a remote Bjorq 3D Worker (recommended for HA add-on)
TRELLIS_MODE=external

# External worker URL (only used when TRELLIS_MODE=external)
# VirtualBox NAT: http://10.0.2.2:8080
# VirtualBox Bridged: http://<windows-lan-ip>:8080
TRELLIS_WORKER_URL=http://10.0.2.2:8080

# Optional Bearer token for worker authentication
TRELLIS_WORKER_TOKEN=
